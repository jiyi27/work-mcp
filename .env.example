# =============================================================================
# Environment variables for work-mcp
#
# Each section below corresponds to a plugin. Variables in a section are only
# required when that plugin is listed under `plugins.enabled` in config.yaml.
# You can safely omit any section whose plugin is not enabled.
# =============================================================================

# -----------------------------------------------------------------------------
# Plugin: dingtalk
# Enable by adding "dingtalk" to plugins.enabled in config.yaml.
# -----------------------------------------------------------------------------
# Required: DingTalk robot webhook URL
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your_token_here
# Optional: robot signing secret, only needed when "加签" is enabled on the robot
DINGTALK_SECRET=SECxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Plugin: jira
# Enable by adding "jira" to plugins.enabled in config.yaml.
# -----------------------------------------------------------------------------
# Required: Jira instance base URL
JIRA_BASE_URL=https://your-jira-instance.example.com
# Required: Jira API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your_jira_api_token_here
# Required: Jira project key this server is allowed to access
JIRA_PROJECT_KEY=PROJECT_KEY

# -----------------------------------------------------------------------------
# Plugin: database
# Enable by adding "database" to plugins.enabled in config.yaml.
# Requires the Microsoft ODBC Driver for SQL Server to be installed on the host.
# The configured database account should be read-only.
# -----------------------------------------------------------------------------
# Required
DB_TYPE=sqlserver
DB_HOST=your-sqlserver-host.example.com
DB_USER=readonly_user
DB_PASSWORD=your_password_here
# Optional: defaults to "master" if not set
DB_NAME=master
# Optional: defaults to 1433 if not set
DB_PORT=1433
# Optional: defaults to "ODBC Driver 18 for SQL Server" if not set
DB_DRIVER=ODBC Driver 18 for SQL Server
# Optional: defaults to true if not set
DB_TRUST_SERVER_CERTIFICATE=true
# Optional: defaults to 5 if not set
DB_CONNECT_TIMEOUT_SECONDS=5
